extends ../layouts/default

block variables
    - 
    var itemsData = [
      {"cardTitle": "Фритрек и нулевой спринт: Подготовка к работе", "cardLabel": "HTML", "cardImgSrc": "./images/image.jpg", "cardImgAlt": "Весёлый хипстерский фургон", "cardIntro": "Это было самое начало пути. На этом этапе важно было проникнуться основами и настроиться на учёбу. И, возможно, подумать, как новые знания могут повлиять на ваше будущее.", "cardMemo": "Место для ваших воспоминаний о начале обучения."}, 
      {"cardTitle": "1 спринт: Я — чистый лист", "cardLabel": "HTML", "cardImgSrc": "./images/image.jpg", "cardImgAlt": "Весёлый хипстерский фургон", "cardIntro": "На первых этапах мы работали со страхами и сомнениями, которые часто испытывают новички. Один из них — страх перед чистым листом. Это, конечно же, намного сложнее, чем боязнь куска бумаги. Часто за этим ощущением скрываются более глубокие вопросы: с чего начать? а вдруг будет слишком сложно? что, если я не справлюсь?", "cardMemo": "Место для ваших воспоминаний о начале обучения."},
      {"cardTitle": "1 спринт: А если не получится?", "cardLabel": "CSS", "cardImgSrc": "./images/image.jpg", "cardImgAlt": "Весёлый хипстерский фургон", "cardIntro": "Первый проект — позади! Но это всё ещё самое начало пути. Радость могла быстро померкнуть и смениться ожиданием провала. Или вы, наоборот, могли вдохновиться успехами и поверить в себя.", "cardMemo": "Место для ваших воспоминаний о начале обучения."},
      {"cardTitle": "2 спринт: Погоня за идеалом", "cardLabel": "desigions", "cardImgSrc": "./images/image.jpg", "cardImgAlt": "Весёлый хипстерский фургон", "cardIntro": "На этом этапе вы уже достаточно разбирались в основах вёрстки, чтобы понять, как много ещё впереди. Вы могли попытаться погнаться за идеалом и понять, что он недостижим. А, может, вы вовсе и не подвержены перфекционизму и вместо того, чтобы сделать идеально, старались просто сделать.", "cardMemo": "Место для ваших воспоминаний о начале обучения."},
      {"cardTitle": "2 спринт: О тех, кто рядом", "cardLabel": "care", "cardImgSrc": "./images/image.jpg", "cardImgAlt": "Весёлый хипстерский фургон", "cardIntro": "Всё это время вы были не одиноки (хотя, возможно, иногда и чувствовали, что одни против целого мира). Вас окружали одногруппники, команда сопровождения и просто близкие люди, которым можно пожаловаться, если очередной макет просто так не поддавался. Осваивать что-то новое легче, когда рядом есть единомышленники, не правда ли?", "cardMemo": "Место для ваших воспоминаний о начале обучения."},
      {"cardTitle": "3 спринт: Обходные стратегии", "cardLabel": "support", "cardImgSrc": "./images/image.jpg", "cardImgAlt": "Весёлый хипстерский фургон", "cardIntro": "На этом курсе вы постоянно решали разные задачи. В какой-то момент вам могло показаться, что решения просто иссякли. Значит, пришло время посмотреть на задачу под другим углом.", "cardMemo": "Место для ваших воспоминаний о начале обучения."},
      {"cardTitle": "3 спринт: Когда опускаются руки", "cardLabel": "lifes-style: none;", "cardImgSrc": "./images/image.jpg", "cardImgAlt": "Весёлый хипстерский фургон", "cardIntro": "Во время учёбы часто возникает чувство, когда не знаешь, за что хвататься. Вроде и проектную пора сдавать, и задачи хочется порешать, и в теории получше разобраться, и жизнь не забыть пожить. В такие моменты очень нужна концентрация. Вспомните, откуда вы её черпали.", "cardMemo": "Место для ваших воспоминаний о начале обучения."},
      {"cardTitle": "«Сейчас я здесь»", "cardLabel": "experience", "cardImgSrc": "./images/image.jpg", "cardImgAlt": "Весёлый хипстерский фургон", "cardIntro": "Сейчас вы уже очень много знаете о вёрстке. Но это только начало. Во-первых, впереди ещё много материала про «красотищу». Во-вторых, с окончанием курса учёба не заканчивается. Вёрстка — это целый мир. И этот мир постоянно меняется. Познать его полностью не получится, но это тот случай, когда важен сам процесс познания. Ведь часто путь — и есть результат.", "cardMemo": "Место для ваших воспоминаний о начале обучения."}
    ] 

block main
  main.main
    section.section.education
      h2.section-title.visually-hidden
      include ../styles/sections/education/__list/__list
        block items
          include ../styles/sections/education/__item/__item
          if itemsData.length > 0
            each item in itemsData 
              +item(item.cardTitle, item.cardLabel, item.cardImgSrc, item.cardImgAlt, item.cardIntro, item.cardMemo)
